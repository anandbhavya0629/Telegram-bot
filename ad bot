# Main function
async def main():

    # Create bot
    app = ApplicationBuilder().token(TOKEN).build()

    # Commands
    app.add_handler(CommandHandler("start", start))

    # Save chats/groups
    app.add_handler(
        MessageHandler(filters.ALL, save_chat)
    )

    # Start auto messaging
    asyncio.create_task(auto_message(app))

    print("✅ Bot Running...")

    # Start polling
    await app.run_polling()

# Run bot
asyncio.run(main())
