from telegram import Update
from telegram.ext import (
    ApplicationBuilder,
    CommandHandler,
    ContextTypes,
    MessageHandler,
    filters,
)

import asyncio

# YOUR BOT TOKEN
TOKEN = "8639818064:AAFtl0XBlHj_T3j4OPilExz0NxE_VhuvLf4"

# Store users/groups
chat_ids = set()

# /start command
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):

    chat_id = update.effective_chat.id

    # Save user/group ID
    chat_ids.add(chat_id)

    await update.message.reply_text(
        "✅ Automatic advertisement messages enabled."
    )

# Save all chats/groups automatically
async def save_chat(update: Update, context: ContextTypes.DEFAULT_TYPE):

    chat_id = update.effective_chat.id

    # Save ID
    chat_ids.add(chat_id)

# Send advertisement every 60 minutes
